# App
PORT=3000
NODE_ENV=development

# Database — local dev: set DATABASE_URL to bypass Secrets Manager
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/teamnotes

# Database — AWS production: unset DATABASE_URL and set these instead
# DB_SECRET_ARN=arn:aws:secretsmanager:us-east-1:<account_id>:secret:team-notes-pro/db-xxxxxx
# AWS_REGION=us-east-1

# Stage 3 — S3 + CloudFront
# VITE_API_URL=https://api.notes.yourdomain.com    (set at frontend build time, not runtime)
# CORS_ORIGIN=https://notes.yourdomain.com         (comma-separate multiple origins)

# Stage 4 — Cognito (backend runtime)
# COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
# COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
# DEV_SKIP_AUTH=true    # bypass JWT validation for local dev without a real Cognito pool

# Stage 4 — Cognito (frontend build time)
# VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
# VITE_COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# Stage 5 — SQS export worker (worker still needs these; no longer used by the API in Stage 8)
# SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/<account_id>/team-notes-pro-exports
# EXPORT_BUCKET=team-notes-pro-exports-<account_id>

# Stage 8 — Step Functions (API needs this; Lambda gets EXPORT_BUCKET + SNS_TOPIC_ARN directly)
# STATE_MACHINE_ARN=arn:aws:states:us-east-1:<account_id>:stateMachine:team-notes-pro-export

# Stage 10 — Observability
# CLOUDWATCH_METRICS=true  (enable custom metric publishing from API ECS task)
# XRAY_ENABLED=true        (enable X-Ray tracing — also requires daemon sidecar in ECS task)

# Stage 9 — EventBridge schedules
# No new env vars — scheduled Lambda actions reuse DB_SECRET_ARN, SNS_TOPIC_ARN, EXPORT_BUCKET
# Cron schedules are configured in AWS; see infra/stage9/schedules.json

# Stage 7 — SNS export notifications (worker only)
# SNS_TOPIC_ARN=arn:aws:sns:us-east-1:<account_id>:team-notes-pro-export-events

# Stage 6 — ElastiCache Redis
# REDIS_URL=redis://team-notes-pro.xxxxxx.0001.use1.cache.amazonaws.com:6379
# For TLS (in-transit encryption enabled): rediss://host:6379
